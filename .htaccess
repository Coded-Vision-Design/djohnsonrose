RewriteEngine On

# ---- Sensitive files: deny all direct access ----
# .env, dotfiles, config/bootstrap, and any PHP file that isn't an entry point.
# Apache 2.4 "Require all denied" + a few explicit allowlist exceptions for
# the files we DO serve at root.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "^(config|bootstrap|router|dev-server)\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "(\.env|\.env\..*|composer\.(json|lock)|package(-lock)?\.json|tsconfig.*\.json|vite\.config\..*|vitest\.config\..*|playwright\.config\..*)$">
    Require all denied
</FilesMatch>

# Force HTTPS in production (skip on localhost dev hosts).
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Friendly admin URLs — both /admin and /adminconsole resolve to the v2
# React app's deep-link route, which auto-launches the Admin Console.
# Putting these BEFORE the v2 SPA rewrite so they hit the redirect first.
RewriteRule ^admin/?$        /v2/app/admin [R=302,L]
RewriteRule ^adminconsole/?$ /v2/app/admin [R=302,L]

# React v2: serve the SPA from /v2/. Real built files under v2/dist/
# (assets/, index.html, favicon, etc.) are served directly. Anything else
# under /v2/ falls back to v2/dist/index.html so React Router can handle it.
#
# [END] (Apache 2.3.9+) terminates the rewrite engine entirely. Plain [L]
# isn't enough here: in .htaccess context Apache restarts mod_rewrite after
# each match — the second pass would re-match v2/dist/... against the SPA
# fallback and serve index.html for every JS chunk, breaking MIME types.
RewriteCond %{DOCUMENT_ROOT}/v2/dist/$1 -f [OR]
RewriteCond %{DOCUMENT_ROOT}/v2/dist/$1 -d
RewriteRule ^v2/(.+)$ v2/dist/$1 [END]
RewriteRule ^v2(/.*)?$ v2/dist/index.html [END]

# v1 (PHP): handle routing to index.php if file/dir doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
