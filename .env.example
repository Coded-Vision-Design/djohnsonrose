# Copy this file to `.env` and fill in real values.
# Never commit `.env` itself.

APP_ENV=production
APP_DEBUG=false

# Contact / email
PORTFOLIO_EMAIL=devante@johnson-rose.co.uk
ADMIN_EMAIL=devante@johnson-rose.co.uk

# SMTP (outbound mail from the Outlook app + telemetry)
MAIL_FROM_ADDRESS=no-reply@johnson-rose.co.uk
MAIL_FROM_NAME="Portfolio OS Notify"
MAIL_PASSWORD=__set_me__
SMTP_HOST=localhost
SMTP_PORT=25

# Google APIs (server-side use)
GOOGLE_API_KEY=__set_me__

# Google OAuth for the admin console.
# Create the credentials in Google Cloud Console > APIs & Services > Credentials.
# Authorized JavaScript origins: https://devante.johnson-rose.co.uk
# Authorized redirect URIs: (not needed for the implicit/id_token flow we use)
GOOGLE_OAUTH_CLIENT_ID=__set_me__.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=__set_me__

# Comma-separated list of Google account emails permitted to sign into the
# admin console. Anyone else's id_token is rejected.
ADMIN_EMAILS=

# 64-hex random string — used to HMAC-sign the admin session cookie.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SESSION_SECRET=__set_me__

# MySQL
DB_HOST=localhost
DB_NAME=portfolio_db
DB_USER=root
DB_PASS=
